# Configuração do banco MySQL (dados fornecidos pela Locaweb)
DB_HOST=mysqlXXX.locaweb.com.br
DB_NAME=seu_banco
DB_USER=seu_usuario
DB_PASS=sua_senha

# Chave para assinar tokens JWT — gere com: openssl rand -hex 32
JWT_SECRET=troque_para_uma_string_aleatoria_de_32_caracteres_ou_mais

# Onde as imagens ficam salvas no servidor
# UPLOAD_DIR é caminho absoluto (ex: /home/usuario/public_html/uploads/vehicles)
# UPLOAD_URL é o caminho público (ex: /uploads/vehicles)
UPLOAD_DIR=/home/USUARIO/public_html/uploads/vehicles
UPLOAD_URL=/uploads/vehicles

# Tempo de vida do token (em segundos). 604800 = 7 dias.
JWT_TTL=604800
